PORT=5000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rhet_ticketing
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=8h
UPLOAD_DIR=uploads

# Optional: certificate PDF generation (used by both certificate types)
# If unset, backend uses backend/assets/supportcertificate.png when present.
# On deployed server, set to absolute path if image is elsewhere, e.g.:
# CERTIFICATE_IMAGE_PATH=/var/www/app/backend/assets/supportcertificate.png
# CERTIFICATE_IMAGE_PATH=

# Optional: Linux server - path to Chromium for PDF generation, e.g.:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_EXECUTABLE_PATH=
