# API base URL for axios (and avatar images unless you omit it in prod same-origin setups).
# Local dev: http://localhost:5000  |  LAN dev: http://YOUR_PC_IP:5000  |  Prod split hosts: https://api.example.com
# Production same-origin (nginx proxies /api and /uploads): leave unset so media uses this site’s origin.
VITE_API_URL=http://localhost:5000
